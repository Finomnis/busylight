{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "probe-rs Launch",
            "type": "probe-rs-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "connectUnderReset": false,
            "chip": "STM32U073CC",
            "flashingConfig": {
                "flashingEnabled": true,
                "haltAfterReset": true
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "./target/thumbv6m-none-eabi/debug/busylight"
                }
            ]
        },
        {
            "name": "probe-rs Attach",
            "type": "probe-rs-debug",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "chip": "STM32U073CC",
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "./target/thumbv6m-none-eabi/debug/busylight"
                }
            ]
        }
    ]
}
