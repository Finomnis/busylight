/dts-v1/;
#include <st/u0/stm32u073Xc.dtsi>
#include <st/u0/stm32u073ccux-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/input/stm32-tsc-defines.h>

/ {
    model = "Finomnis Busylight board";
    compatible = "finomnis,busylight";

    #address-cells = <1>;
    #size-cells = <1>;

    chosen {
        zephyr,console = &usart2;
        zephyr,shell-uart = &usart2;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,code-partition = &slot0_partition;
        zephyr,uart-mcumgr = &cdc_acm_uart0;
    };

    /delete-node/ sram1;
    /delete-node/ sram2;

    sram1: memory@20000000 {
        reg = <0x20000000 DT_SIZE_K(40)>;
    };
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        /*
         * Following flash partition is dedicated to the use of nucleo_u5a5zj_q
         * with TZEN=0 (so w/o TFM).
         */
        boot_partition: partition@0 {
            label = "mcuboot";
            reg = <0x00000000 DT_SIZE_K(64)>;
        };

        slot0_partition: partition@10000 {
            label = "image-0";
            reg = <0x00010000 DT_SIZE_K(88)>;
        };

        slot1_partition: partition@26000 {
            label = "image-1";
            reg = <0x00026000 DT_SIZE_K(88)>;
        };

        storage_partition: partition@3c000 {
            label = "storage";
            reg = <0x0003c000 DT_SIZE_K(16)>;
        };
    };
};

&usart2 {
    pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
    pinctrl-names = "default";
    current-speed = <115200>;
    status = "okay";
};

&clk_hsi {
    status = "okay";
};

&pll {
    div-m = <1>;
    mul-n = <6>;
    div-p = <2>;
    div-q = <2>;
    div-r = <2>;
    clocks = <&clk_hsi>;
    status = "okay";
};

&rcc {
    clocks = <&pll>;
    clock-frequency = <DT_FREQ_M(48)>;
    ahb-prescaler = <1>;
    apb1-prescaler = <1>;
};

stm32_lp_tick_source: &lptim2 {
    clocks = <&rcc STM32_CLOCK(APB1, 30)>,
             <&rcc STM32_SRC_LSI LPTIM2_SEL(1)>;
    status = "okay";
};

zephyr_udc0: &usb {
    pinctrl-0 = <&usb_dm_pa11 &usb_dp_pa12>;
    pinctrl-names = "default";
    status = "okay";

    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
    };
};

&clk_hsi48 {
    crs-usb-sof;
    status = "okay";
};

&clk48 {
    clocks = <&rcc STM32_SRC_HSI48 CLK48_SEL(3)>;
    status = "okay";
};
